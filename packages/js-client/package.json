{
  "name": "@murmur/client",
  "version": "0.1.0",
  "description": "TypeScript client for Murmur agent servers — browser + Node compatible.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agents",
    "murmur",
    "client",
    "ai"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
